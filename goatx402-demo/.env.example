# GoatX402 Demo Configuration
# Copy this file to .env and fill in your values

# Backend Server Configuration (keep these secret!)
GOATX402_MERCHANT_ID=your_merchant_id_here
GOATX402_API_URL=http://localhost:8286
GOATX402_API_KEY=your_api_key_here
GOATX402_API_SECRET=your_api_secret_here

# Server port (optional)
PORT=3001

# Payride: AI agent (optional; without it, "Let agent book" returns 503)
GROQ_API_KEY=your_groq_api_key_here
